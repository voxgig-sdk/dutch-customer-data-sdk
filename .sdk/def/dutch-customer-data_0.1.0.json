    "/password": {
      "get": {
        "summary": "Check password security",
        "description": "Checks how many times a password has been seen/leaked. Returns wrong_password: 1 if found count exceeds threshold.",
        "operationId": "checkPassword",
        "tags": [
          "Global APIs"
        ],
        "parameters": [
          {
            "name": "password_sha1",
            "in": "query",
            "description": "SHA1 hash of password (recommended)",
            "required": false,
            "schema": {
              "type": "string",
              "example": "2c4c3891e2ac6958e9810a1e49c6705784fbfa1a"
            }
          },
          {
            "name": "password",
            "in": "query",
            "description": "Plain password (use POST method)",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "threshold",
            "in": "query",
            "description": "Threshold for leak count (default: 25)",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 25
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "password": {
                      "type": "object",
                      "properties": {
                        "found": {
                          "type": "integer"
                        },
                        "wrong_password": {
                          "type": "integer"
                        },
                        "success": {
                          "type": "integer"
                        },
                        "message": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Check password security (POST)",
        "description": "Checks how many times a password has been seen/leaked using POST method for security.",
        "operationId": "checkPasswordPost",
        "tags": [
          "Global APIs"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "password": {
                    "type": "string",
                    "description": "Plain password to check"
                  },
                  "password_sha1": {
                    "type": "string",
                    "description": "SHA1 hash of password (recommended)"
                  },
                  "threshold": {
                    "type": "integer",
                    "default": 25,
                    "description": "Threshold for leak count"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "password": {
                      "type": "object",
                      "properties": {
                        "found": {
                          "type": "integer"
                        },
                        "wrong_password": {
                          "type": "integer"
                        },
                        "success": {
                          "type": "integer"
                        },
                        "message": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
