{
  "openapi": "3.0.3",
  "info": {
    "title": "Dutch Customer Data API",
    "description": "Verify and standardize Dutch customer and business data, including addresses, phone numbers, emails, URLs, VAT, IBAN, Chamber of Commerce (KvK) numbers, and postal codes. Forever free (no auth, https/cors enabled) APIs to check and standardize your data.",
    "version": "1.1",
    "contact": {
      "name": "Bedrijfsdata.nl",
      "url": "https://free.bedrijfsdata.nl"
    }
  },
  "servers": [
    {
      "url": "https://free.bedrijfsdata.nl/v1.1",
      "description": "Production server"
    }
  ],
  "paths": {
    "/phone": {
      "get": {
        "summary": "Verify phone number",
        "description": "Checks if a phone number could exist (global). Validates format and provides international/national formatting.",
        "operationId": "verifyPhone",
        "tags": [
          "Global APIs"
        ],
        "parameters": [
          {
            "name": "phone",
            "in": "query",
            "description": "Phone number to verify (can include country code with +)",
            "required": true,
            "schema": {
              "type": "string",
              "example": "+31207895050"
            }
          },
          {
            "name": "country_code",
            "in": "query",
            "description": "ISO country code (e.g., 'nl' for Netherlands)",
            "required": false,
            "schema": {
              "type": "string",
              "example": "nl"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "ok"
                    },
                    "phone": {
                      "type": "object",
                      "properties": {
                        "int": {
                          "type": "string",
                          "description": "International format without plus sign"
                        },
                        "valid": {
                          "type": "integer",
                          "description": "1 if valid, 0 if not"
                        },
                        "international": {
                          "type": "string",
                          "description": "International formatted phone number"
                        },
                        "national": {
                          "type": "string",
                          "description": "National formatted phone number"
                        },
                        "country": {
                          "type": "string",
                          "description": "ISO country code"
                        },
                        "region": {
                          "type": "string",
                          "description": "Geographic region"
                        },
                        "carrier": {
                          "type": "string",
                          "description": "Carrier name"
                        },
                        "ismobile": {
                          "type": "integer",
                          "description": "1 if mobile, 0 if not"
                        },
                        "success": {
                          "type": "integer",
                          "description": "1 if successful, 0 if not"
                        },
                        "wrong_phone": {
                          "type": "integer",
                          "description": "1 if wrong, 0 if correct"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/postcode": {
      "get": {
        "summary": "Verify postal code",
        "description": "Checks if a postcode is in the right format (global). Returns location details if found.",
        "operationId": "verifyPostcode",
        "tags": [
          "Global APIs"
        ],
        "parameters": [
          {
            "name": "postcode",
            "in": "query",
            "description": "Postal code to verify",
            "required": true,
            "schema": {
              "type": "string",
              "example": "1013PN"
            }
          },
          {
            "name": "country_code",
            "in": "query",
            "description": "ISO country code",
            "required": true,
            "schema": {
              "type": "string",
              "example": "NL"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "ok"
                    },
                    "success": {
                      "type": "integer"
                    },
                    "wrong_postcode": {
                      "type": "integer"
                    },
                    "message": {
                      "type": "string"
                    },
                    "found": {
                      "type": "integer"
                    },
                    "postcode": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "postcode": {
                            "type": "string"
                          },
                          "city": {
                            "type": "string"
                          },
                          "admin1": {
                            "type": "string"
                          },
                          "admin2": {
                            "type": "string"
                          },
                          "admin3": {
                            "type": "string",
                            "nullable": true
                          },
                          "lat": {
                            "type": "number",
                            "format": "double"
                          },
                          "lon": {
                            "type": "number",
                            "format": "double"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/city": {
      "get": {
        "summary": "Search city details",
        "description": "Search for city details including population and geographic coordinates.",
        "operationId": "searchCity",
        "tags": [
          "Global APIs"
        ],
        "parameters": [
          {
            "name": "city",
            "in": "query",
            "description": "City name to search",
            "required": true,
            "schema": {
              "type": "string",
              "example": "Haarlem"
            }
          },
          {
            "name": "country_code",
            "in": "query",
            "description": "ISO country code",
            "required": true,
            "schema": {
              "type": "string",
              "example": "NL"
            }
          },
          {
            "name": "full",
            "in": "query",
            "description": "Set to 1 for city verification instead of suggestion",
            "required": false,
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "found": {
                      "type": "integer"
                    },
                    "city": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "city": {
                            "type": "string"
                          },
                          "population": {
                            "type": "integer"
                          },
                          "lat": {
                            "type": "number",
                            "format": "double"
                          },
                          "lon": {
                            "type": "number",
                            "format": "double"
                          },
                          "admin1": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/geocoding": {
      "get": {
        "summary": "Geocode address",
